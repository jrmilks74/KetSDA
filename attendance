# Baccalaureate-specific forecasting adjustments ----------------------------
# The Saturday before Memorial Day uses an estimate learned from prior
# baccalaureate services and the surrounding non-event weeks.


# Locale-independent calculation of recurring service weeks -----------------

make_holiday_df_weekly <- function(date_range) {
        yrs <- seq(
                lubridate::year(min(date_range, na.rm = TRUE)) - 1L,
                lubridate::year(max(date_range, na.rm = TRUE)) + 1L
        )
        
        wk_monday <- function(d) {
                lubridate::floor_date(as.Date(d), "week", week_start = 1)
        }
        
        easter_sun <- as.Date(timeDate::Easter(yrs))
        easter_sat <- easter_sun - 1L
        
        dec25 <- as.Date(paste0(yrs, "-12-25"))
        christmas_service <- dec25 -
                ((lubridate::wday(dec25, week_start = 1) - 6L) %% 7L)
        
        # Memorial Day is the last Monday in May.  This calculation does not
        # depend on the machine's language/locale, unlike weekdays().
        may31 <- as.Date(paste0(yrs, "-05-31"))
        memorial_mon <- may31 -
                ((lubridate::wday(may31, week_start = 1) - 1L) %% 7L)
        baccalaureate_sat <- memorial_mon - 2L
        
        make_h <- function(name, dates) {
                tibble::tibble(
                        holiday = name,
                        ds = unique(wk_monday(dates)),
                        lower_window = 0,
                        upper_window = 0
                )
        }
        
        dplyr::bind_rows(
                make_h("Easter_Saturday", easter_sat),
                make_h("Christmas_Service", christmas_service),
                # Keep the old internal name so the rest of the app remains
                # backward compatible.
                make_h("Graduation_Saturday", baccalaureate_sat),
                make_h("MemorialDay_Week", memorial_mon)
        ) |>
                dplyr::distinct(holiday, ds, .keep_all = TRUE)
}


# Dedicated baccalaureate event model ----------------------------------------

.winsorized_weighted_mean <- function(x, w, probs = c(0.10, 0.90)) {
        ok <- is.finite(x) & is.finite(w) & w > 0
        x <- x[ok]
        w <- w[ok]
        
        if (!length(x)) return(NA_real_)
        if (length(x) == 1L) return(x[[1]])
        
        lim <- stats::quantile(x, probs = probs, na.rm = TRUE, names = FALSE)
        x <- pmin(pmax(x, lim[[1]]), lim[[2]])
        stats::weighted.mean(x, w)
}

.baccalaureate_history <- function(series_tbl,
                                   lookback_years = 5L,
                                   flank_weeks = 3L) {
        x <- series_tbl |>
                dplyr::arrange(date) |>
                dplyr::mutate(date = as.Date(date))
        
        event_rows <- x |>
                dplyr::filter(is_graduation_sat == 1L, is.finite(value)) |>
                dplyr::select(date, value)
        
        if (!nrow(event_rows)) {
                return(tibble::tibble(
                        date = as.Date(character()),
                        value = numeric(),
                        local_base = numeric(),
                        delta = numeric(),
                        ratio = numeric()
                ))
        }
        
        local_base <- vapply(event_rows$date, function(event_date) {
                neighbours <- x |>
                        dplyr::filter(
                                date >= event_date - lubridate::weeks(flank_weeks),
                                date <= event_date + lubridate::weeks(flank_weeks),
                                date != event_date,
                                is_easter_sat == 0L,
                                is_christmas_service == 0L,
                                is_graduation_sat == 0L,
                                is_memorial_week == 0L,
                                is.finite(value)
                        ) |>
                        dplyr::pull(value)
                
                if (length(neighbours) < 2L) NA_real_ else stats::median(neighbours)
        }, numeric(1))
        
        event_rows |>
                dplyr::mutate(
                        local_base = local_base,
                        delta = value - local_base,
                        ratio = dplyr::if_else(
                                is.finite(local_base) & local_base > 0,
                                value / local_base,
                                NA_real_
                        )
                ) |>
                dplyr::filter(is.finite(local_base), is.finite(delta), is.finite(ratio)) |>
                dplyr::arrange(dplyr::desc(date)) |>
                dplyr::slice_head(n = lookback_years) |>
                dplyr::arrange(date)
}

.estimate_baccalaureate_effect <- function(history, half_life_years = 2.0) {
        n_events <- nrow(history)
        if (!n_events) {
                return(list(
                        n = 0L,
                        add = 0,
                        ratio = 1,
                        sigma = 0
                ))
        }
        
        age <- max(lubridate::year(history$date)) - lubridate::year(history$date)
        recency_weight <- 0.5 ^ (age / half_life_years)
        
        add_est <- .winsorized_weighted_mean(history$delta, recency_weight)
        ratio_est <- .winsorized_weighted_mean(history$ratio, recency_weight)
        
        if (!is.finite(add_est)) add_est <- 0
        if (!is.finite(ratio_est)) ratio_est <- 1
        
        # The church describes this as a consistently high-attendance event;
        # do not learn a negative "uplift" from noisy or incomplete history.
        add_est <- max(add_est, 0)
        ratio_est <- max(ratio_est, 1)
        
        add_sigma <- if (n_events >= 2L) stats::mad(history$delta, na.rm = TRUE) else 0
        ratio_sigma <- if (n_events >= 2L) stats::mad(history$ratio, na.rm = TRUE) else 0
        
        list(
                n = n_events,
                add = add_est,
                ratio = ratio_est,
                add_sigma = if (is.finite(add_sigma)) add_sigma else 0,
                ratio_sigma = if (is.finite(ratio_sigma)) ratio_sigma else 0,
                history = history
        )
}


compute_event_uplifts <- function(series_tbl, lookback_years = 5L) {
        out <- .compute_event_uplifts_base(
                series_tbl,
                lookback_years = min(lookback_years, 3L)
        )
        
        history <- .baccalaureate_history(
                series_tbl,
                lookback_years = lookback_years
        )
        out$baccalaureate <- .estimate_baccalaureate_effect(history)
        out
}


.forecast_local_baseline <- function(pred, event_date, flank_weeks = 3L) {
        nearby <- pred |>
                dplyr::filter(
                        .index >= event_date - lubridate::weeks(flank_weeks),
                        .index <= event_date + lubridate::weeks(flank_weeks),
                        .index != event_date,
                        is.finite(.value)
                ) |>
                dplyr::pull(.value)
        
        if (length(nearby) < 2L) {
                nearby <- pred |>
                        dplyr::filter(
                                .index >= event_date - lubridate::weeks(6L),
                                .index <= event_date + lubridate::weeks(6L),
                                .index != event_date,
                                is.finite(.value)
                        ) |>
                        dplyr::pull(.value)
        }
        
        if (!length(nearby)) NA_real_ else stats::median(nearby)
}


apply_event_uplifts <- function(fc_all, future_tbl, uplifts,
                                grad_add_shrink = 0.60,
                                grad_mult_shrink = 0.25,
                                grad_cap_buffer = 0.02,
                                min_mult_easter = 0.15,
                                min_mult_xmas = 0.15,
                                min_mult_grad = 0.05) {
        legacy_uplifts <- uplifts
        legacy_uplifts$grad$add <- 0
        legacy_uplifts$grad$mult <- 0
        legacy_uplifts$grad$max <- NA_real_
        
        out <- .apply_event_uplifts_base(
                fc_all = fc_all,
                future_tbl = future_tbl,
                uplifts = legacy_uplifts,
                grad_add_shrink = 0,
                grad_mult_shrink = 0,
                grad_cap_buffer = grad_cap_buffer,
                min_mult_easter = min_mult_easter,
                min_mult_xmas = min_mult_xmas,
                min_mult_grad = 0
        )
        
        effect <- uplifts$baccalaureate
        if (is.null(effect) || effect$n == 0L) return(out)
        
        event_dates <- future_tbl |>
                dplyr::filter(is_graduation_sat == 1L) |>
                dplyr::pull(date) |>
                as.Date()
        
        if (!length(event_dates)) return(out)
        
        pred <- out |>
                dplyr::filter(.key == "prediction") |>
                dplyr::mutate(.index = as.Date(.index))
        
        # With three or more observed baccalaureates, the event estimate gets
        # most of the weight.  Smaller samples are automatically conservative.
        reliability <- effect$n / (effect$n + 0.5)
        
        for (event_date_raw in event_dates) {
                # A base R for-loop drops the Date class from individual
                # elements, so restore it explicitly before date arithmetic.
                event_date <- as.Date(event_date_raw, origin = "1970-01-01")
                local_base <- .forecast_local_baseline(pred, event_date)
                if (!is.finite(local_base)) next
                
                by_addition <- local_base + effect$add
                by_ratio <- local_base * effect$ratio
                event_target <- mean(c(by_addition, by_ratio), na.rm = TRUE)
                event_target <- local_base + reliability * (event_target - local_base)
                event_target <- max(event_target, local_base, 0)
                
                row_id <- which(
                        out$.key == "prediction" & as.Date(out$.index) == event_date
                )
                if (!length(row_id)) next
                
                old_half_width <- suppressWarnings(mean(c(
                        out$.value[row_id] - out$.conf_lo[row_id],
                        out$.conf_hi[row_id] - out$.value[row_id]
                ), na.rm = TRUE))
                if (!is.finite(old_half_width)) old_half_width <- 0
                
                event_sigma <- mean(c(
                        effect$add_sigma,
                        local_base * effect$ratio_sigma
                ), na.rm = TRUE)
                if (!is.finite(event_sigma)) event_sigma <- 0
                
                # Combine ordinary forecast uncertainty with variability in the
                # event uplift.  1.281552 is the two-sided 80% normal multiplier.
                event_half_width <- sqrt(
                        old_half_width^2 + (1.281552 * event_sigma)^2
                )
                
                out$.value[row_id] <- event_target
                out$.conf_lo[row_id] <- pmax(0, event_target - event_half_width)
                out$.conf_hi[row_id] <- event_target + event_half_width
        }
        
        out
}


# Leave-one-year-out diagnostic shown beside the ordinary model metrics -------

.baccalaureate_backtest <- function(series_tbl, lookback_years = 5L) {
        history <- .baccalaureate_history(
                series_tbl,
                lookback_years = lookback_years
        )
        
        if (nrow(history) < 3L) {
                return(tibble::tibble(
                        model_id = NA_integer_,
                        model_desc = "Baccalaureate event adjustment (insufficient history)",
                        rmse = NA_real_, mae = NA_real_, mape = NA_real_,
                        rsq = NA_real_, weight = NA_real_
                ))
        }
        
        forecasts <- lapply(3:nrow(history), function(i) {
                train <- history[seq_len(i - 1L), , drop = FALSE]
                test <- history[i, , drop = FALSE]
                est <- .estimate_baccalaureate_effect(train)
                reliability <- est$n / (est$n + 0.5)
                raw <- mean(c(
                        test$local_base + est$add,
                        test$local_base * est$ratio
                ))
                prediction <- test$local_base + reliability * (raw - test$local_base)
                
                tibble::tibble(actual = test$value, prediction = prediction)
        }) |>
                dplyr::bind_rows()
        
        err <- forecasts$prediction - forecasts$actual
        tibble::tibble(
                model_id = NA_integer_,
                model_desc = paste0(
                        "Baccalaureate event adjustment (", nrow(forecasts),
                        " rolling tests)"
                ),
                rmse = sqrt(mean(err^2, na.rm = TRUE)),
                mae = mean(abs(err), na.rm = TRUE),
                mape = mean(abs(err / forecasts$actual), na.rm = TRUE) * 100,
                rsq = NA_real_,
                weight = NA_real_
        )
}

fit_ensemble_weighted <- function(series_tbl, holidays_df,
                                  horizon_weeks = 13, conf = 0.80) {
        out <- .fit_ensemble_weighted_base(
                series_tbl = series_tbl,
                holidays_df = holidays_df,
                horizon_weeks = horizon_weeks,
                conf = conf
        )
        
        event_accuracy <- .baccalaureate_backtest(series_tbl)
        out$accuracy <- out$accuracy |>
                normalize_metric_names() |>
                dplyr::bind_rows(event_accuracy)
        out
}

