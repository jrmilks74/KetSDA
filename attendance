monthly_mean <- function(df) {
        df |>
                group_by(Date = floor_date(Date, "month")) |>
                summarise(attendance = round(mean(.data$val, na.rm = TRUE), 2), .groups = "drop")
}

summarise_triplet <- function(df) {
        tibble(
                Total     = round(mean(df$Total,     na.rm = TRUE), 2),
                In_person = round(mean(df$In_person, na.rm = TRUE), 2),
                Online    = round(mean(df$Online,    na.rm = TRUE), 2)
        )
}

matched_mtd_yoy_triplets <- function(base_df) {
        df <- base_df |>
                arrange(Date) |>
                mutate(
                        Year     = year(Date),
                        MonthNum = month(Date)
                )
        
        latest_date <- max(df$Date, na.rm = TRUE)
        curr_year   <- year(latest_date)
        prev_year   <- curr_year - 1
        curr_month  <- month(latest_date)
        
        curr_month_df <- df |>
                filter(Year == curr_year, MonthNum == curr_month) |>
                arrange(Date)
        
        prev_month_df <- df |>
                filter(Year == prev_year, MonthNum == curr_month) |>
                arrange(Date)
        
        curr_n <- nrow(curr_month_df)
        prev_n <- nrow(prev_month_df)
        n_compare <- min(curr_n, prev_n)
        
        curr_cmp <- if (n_compare > 0) {
                curr_month_df |>
                        slice_head(n = n_compare) |>
                        summarise_triplet()
        } else {
                tibble(Total = NA_real_, In_person = NA_real_, Online = NA_real_)
        }
        
        prev_cmp <- if (n_compare > 0) {
                prev_month_df |>
                        slice_head(n = n_compare) |>
                        summarise_triplet()
        } else {
                tibble(Total = NA_real_, In_person = NA_real_, Online = NA_real_)
        }
        
        list(
                curr = curr_cmp,
                prev = prev_cmp,
                curr_year = curr_year,
                prev_year = prev_year,
                curr_month_lbl = month(latest_date, label = TRUE),
                curr_n = curr_n,
                prev_n = prev_n,
                n_compare = n_compare,
                latest_date = latest_date
        )
}

full_month_yoy_triplets <- function(base_df) {
        latest_date <- max(base_df$Date, na.rm = TRUE)
        current_month_start <- floor_date(latest_date, "month")
        last_complete_month_end <- current_month_start - days(1)
        last_complete_month_start <- floor_date(last_complete_month_end, "month")
        prev_year_month_start <- last_complete_month_start %m-% years(1)
        prev_year_month_end <- ceiling_date(prev_year_month_start, "month") - days(1)
        
        curr_month_df <- base_df |>
                filter(Date >= last_complete_month_start, Date <= last_complete_month_end) |>
                arrange(Date)
        
        prev_month_df <- base_df |>
                filter(Date >= prev_year_month_start, Date <= prev_year_month_end) |>
                arrange(Date)
        
        curr_cmp <- if (nrow(curr_month_df) > 0) {
                summarise_triplet(curr_month_df)
        } else {
                tibble(Total = NA_real_, In_person = NA_real_, Online = NA_real_)
        }
        
        prev_cmp <- if (nrow(prev_month_df) > 0) {
                summarise_triplet(prev_month_df)
        } else {
                tibble(Total = NA_real_, In_person = NA_real_, Online = NA_real_)
        }
        
        list(
                curr = curr_cmp,
                prev = prev_cmp,
                curr_year = year(last_complete_month_start),
                prev_year = year(prev_year_month_start),
                curr_month_lbl = month(last_complete_month_start, label = TRUE),
                curr_weeks = nrow(curr_month_df),
                prev_weeks = nrow(prev_month_df)
        )
}

safe_pct_change <- function(delta, prev) {
        ifelse(is.na(prev) | prev == 0, NA_real_, delta / prev)
}

yoy_delta <- function(curr, prev) {
        delta_total <- round(curr$Total - prev$Total, 1)
        delta_in    <- round(curr$In_person - prev$In_person, 1)
        delta_on    <- round(curr$Online - prev$Online, 1)
        
        tibble(
                Total     = delta_total,
                In_person = delta_in,
                Online    = delta_on,
                Total_percent     = safe_pct_change(delta_total, prev$Total),
                In_person_percent = safe_pct_change(delta_in, prev$In_person),
                Online_percent    = safe_pct_change(delta_on, prev$Online)
        )
}

fmt_pct <- function(x) {
        ifelse(is.na(x) | is.infinite(x), NA_character_, label_percent(0.1)(x))
}

ytd_averages <- function(df_base) {
        latest_date <- max(df_base$Date, na.rm = TRUE)
        
        curr_year_start <- floor_date(latest_date, "year")
        prev_latest_date <- latest_date %m-% years(1)
        prev_year_start <- floor_date(prev_latest_date, "year")
        
        curr_yr <- df_base |>
                filter(Date >= curr_year_start, Date <= latest_date)
        
        past_year <- df_base |>
                filter(Date >= prev_year_start, Date <= prev_latest_date)
        
        curr_year <- year(latest_date)
        prev_year <- year(prev_latest_date)
        curr_month_lbl <- month(latest_date, label = TRUE)
        
        weekly_ave_past <- summarise(
                past_year,
                Total     = round(mean(Total,     na.rm = TRUE), 1),
                In_person = round(mean(In_person, na.rm = TRUE), 1),
                Online    = round(mean(Online,    na.rm = TRUE), 1)
        )
        
        weekly_ave_curr <- summarise(
                curr_yr,
                Total     = round(mean(Total,     na.rm = TRUE), 2),
                In_person = round(mean(In_person, na.rm = TRUE), 2),
                Online    = round(mean(Online,    na.rm = TRUE), 2)
        )
        
        list(
                latest_date = latest_date,
                prev_latest_date = prev_latest_date,
                curr_year = curr_year,
                prev_year = prev_year,
                curr_month_lbl = curr_month_lbl,
                weekly_ave_past = weekly_ave_past,
                weekly_ave_curr = weekly_ave_curr,
                curr_n = nrow(curr_yr),
                prev_n = nrow(past_year)
        )
}

make_mtd_table <- function(mtd_yoy) {
        deltas <- yoy_delta(mtd_yoy$curr, mtd_yoy$prev)
        
        mat <- matrix(c(
                mtd_yoy$curr$Total,     mtd_yoy$prev$Total,     deltas$Total,     fmt_pct(deltas$Total_percent),
                mtd_yoy$curr$In_person, mtd_yoy$prev$In_person, deltas$In_person, fmt_pct(deltas$In_person_percent),
                mtd_yoy$curr$Online,    mtd_yoy$prev$Online,    deltas$Online,    fmt_pct(deltas$Online_percent)
        ), nrow = 3, byrow = TRUE)
        
        colnames(mat) <- c(
                paste0(mtd_yoy$curr_month_lbl, " ", mtd_yoy$curr_year, " MTD (", mtd_yoy$curr_n, " wks)"),
                paste0(mtd_yoy$curr_month_lbl, " ", mtd_yoy$prev_year, " Matched (", mtd_yoy$n_compare, " wks)"),
                "Change",
                "Percent change"
        )
        
        rownames(mat) <- c("Combined", "In person", "Online")
        mat
}

