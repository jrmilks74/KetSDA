                        col <- selected_column()
                        recent <- base_df() |>
                                filter(!is.na(.data[[col]])) |>
                                arrange(Date) |>
                                slice_tail(n = 2)
                        current <- if (nrow(recent) >= 1) tail(recent[[col]], 1) else NA_real_
                        previous <- if (nrow(recent) >= 2) recent[[col]][nrow(recent) - 1] else NA_real_
                        latest_date <- if (nrow(recent)) max(recent$Date) else as.Date(NA)
                        kpi_card(
                                "Last week",
                                current,
                                comparison_ui(current, previous, "from the prior week"),
                                if (is.na(latest_date)) "No recent date" else format(latest_date, "%B %d, %Y"),
                                accuracy = 1
                        )
                })
                
                output$mtd_card <- renderUI({
                        comparison <- matched_mtd_yoy_triplets(base_df())
                        col <- selected_column()
                        current <- selected_value(comparison$curr, col)
                        previous <- selected_value(comparison$prev, col)
                        kpi_card(
                                "Month-to-date average",
                                current,
                                comparison_ui(current, previous, "year over year"),
                                paste(comparison$curr_month_lbl, "·", comparison$n_compare, "matched weeks")
                        )
                })
                
                output$ytd_card <- renderUI({
                        flags <- curr_flags()
                        col <- selected_column()
                        current <- selected_value(flags$weekly_ave_curr, col)
                        previous <- selected_value(flags$weekly_ave_past, col)
                        kpi_card(
                                "Year-to-date average",
                                current,
                                comparison_ui(current, previous, "year over year"),
                                paste(flags$curr_n, "service weeks")
                        )
                })
                
                output$overview_chart_title <- renderText({
                        paste(selected_service_label(), "·", selected_label())
                })
                
                output$trend_chart_title <- renderText({
                        paste(selected_service_label(), selected_label(), "attendance over time")
                })
                
                output$mtd_table <- renderUI({
                        tbl <- kbl(make_mtd_table(matched_mtd_yoy_triplets(base_df())), row.names = TRUE) |>
                                kable_styling(bootstrap_options = c("striped", "responsive"), full_width = TRUE) |>
                                add_header_above(c(" " = 1, "Matched month-to-date weekly average" = 2, "Year-over-year" = 2)) |>
                                column_spec(1, bold = TRUE)
                        HTML(as.character(tbl))
                })
                
                output$fullmonth_table <- renderUI({
                        tbl <- kbl(make_fullmonth_table(full_month_yoy_triplets(base_df())), row.names = TRUE) |>
                                kable_styling(bootstrap_options = c("striped", "responsive"), full_width = TRUE) |>
                                add_header_above(c(" " = 1, "Full-month weekly average" = 2, "Year-over-year" = 2)) |>
                                column_spec(1, bold = TRUE)
                        HTML(as.character(tbl))
                })
                
                output$ytd_table <- renderUI({
                        tbl <- kbl(make_ytd_table(curr_flags()), row.names = TRUE) |>
                                kable_styling(bootstrap_options = c("striped", "responsive"), full_width = TRUE) |>
                                add_header_above(c(" " = 1, "Year-to-date weekly average" = 2, " " = 1, " " = 1)) |>
                                column_spec(1, bold = TRUE)
                        HTML(as.character(tbl))
                })
                
                output$overview_trend <- renderPlotly({
                        col <- selected_column()
                        d <- base_df() |>
                                transmute(Date, attendance = .data[[col]]) |>
                                filter(!is.na(attendance))
                        
                        p <- plot_ly(
                                d,
                                x = ~Date,
                                y = ~attendance,
                                type = "scatter",
                                mode = "lines+markers",
                                line = list(color = selected_color(), width = 3),
                                marker = list(color = selected_color(), size = 6),
                                text = ~paste0(
                                        format(Date, "%B %d, %Y"),
                                        "<br>", selected_label(), ": ", comma(round(attendance))
                                ),
                                hoverinfo = "text",
                                name = selected_label()
                        ) |>
                                layout(
                                        xaxis = list(title = "", rangeslider = list(visible = FALSE)),
                                        yaxis = list(title = "Attendance", rangemode = "tozero", tickformat = ",d"),
                                        margin = list(l = 65, r = 25, b = 55, t = 20),
                                        hovermode = "x unified",
                                        showlegend = FALSE
                                ) |>
                                config(displaylogo = FALSE, responsive = TRUE)
                        p
                })
                
                selected_months <- reactive({
                        selected <- month_key[[input$month]]
                        if (is.na(selected)) 1:12 else selected
                })
                
                output$seasonal <- renderPlotly({
                        d <- selected_monthly() |>
                                filter(month(Date) %in% selected_months()) |>
                                mutate(
                                        hover = paste0(
                                                format(Date, "%B %Y"),
                                                "<br>Weekly average: ", comma(round(attendance, 1), accuracy = 0.1)
                                        )
                                )
                        
                        plot_ly(
                                d,
                                x = ~Date,
                                y = ~attendance,
                                type = "scatter",
                                mode = "lines",
                                line = list(color = selected_color(), width = 3),
                                text = ~hover,
                                hoverinfo = "text",
                                name = selected_label()
                        ) |>
                                layout(
                                        xaxis = list(title = ""),
                                        yaxis = list(title = "Average attendance", rangemode = "tozero", tickformat = ",d"),
                                        margin = list(l = 65, r = 25, b = 55, t = 20),
                                        hovermode = "x unified",
                                        showlegend = FALSE
                                ) |>
                                config(displaylogo = FALSE, responsive = TRUE)
                })
                
                output$spaghetti <- renderPlotly({
                        flags <- curr_flags()
                        monthly <- selected_monthly() |>
                                filter(is.finite(attendance)) |>
                                mutate(
                                        YearNumber = year(Date),
                                        MonthNumber = month(Date),
                                        PlotDate = as.Date(sprintf("2000-%02d-01", MonthNumber)),
                                        hover = paste0(
                                                format(Date, "%B %Y"),
                                                "<br>Weekly average: ", comma(round(attendance, 1), accuracy = 0.1)
                                        )
                                )
                        
                        history <- monthly |>
                                filter(
                                        YearNumber >= flags$curr_year - 10,
                                        YearNumber <= flags$curr_year - 1
                                )
                        
                        benchmark <- history |>
                                group_by(MonthNumber, PlotDate) |>
                                summarise(
                                        median_attendance = median(attendance, na.rm = TRUE),
                                        lower_80 = quantile(attendance, probs = 0.10, na.rm = TRUE, names = FALSE),
                                        upper_80 = quantile(attendance, probs = 0.90, na.rm = TRUE, names = FALSE),
                                        history_years = n_distinct(YearNumber),
                                        .groups = "drop"
                                ) |>
                                arrange(PlotDate) |>
                                mutate(
                                        median_hover = paste0(
                                                month(PlotDate, label = TRUE, abbr = FALSE),
                                                "<br>10-year median: ", comma(round(median_attendance, 1), accuracy = 0.1),
                                                "<br>Central 80%: ", comma(round(lower_80, 1), accuracy = 0.1),
                                                "–", comma(round(upper_80, 1), accuracy = 0.1),
                                                "<br>Years available: ", history_years
                                        )
                                )
                        
                        current_year <- monthly |> filter(YearNumber == flags$curr_year) |> arrange(PlotDate)
                        previous_year <- monthly |> filter(YearNumber == flags$prev_year) |> arrange(PlotDate)
                        
                        p <- plot_ly()
                        
                        if (nrow(benchmark)) {
                                p <- p |>
                                        add_ribbons(
                                                data = benchmark,
                                                x = ~PlotDate,
                                                ymin = ~lower_80,
                                                ymax = ~upper_80,
                                                name = "Historical central 80%",
                                                fillcolor = "rgba(185, 191, 191, 0.38)",
                                                line = list(color = "rgba(185, 191, 191, 0)"),
                                                hoverinfo = "skip",
                                                opacity = 1
                                        ) |>
                                        add_lines(
                                                data = benchmark,
                                                x = ~PlotDate,
                                                y = ~median_attendance,
                                                name = "10-year median",
                                                line = list(color = "#505858", width = 3),
                                                text = ~median_hover,
                                                hoverinfo = "text"
                                        )
                        }
                        
                        if (nrow(previous_year)) {
                                p <- p |>
                                        add_lines(
                                                data = previous_year,
                                                x = ~PlotDate,
                                                y = ~attendance,
                                                name = as.character(flags$prev_year),
                                                line = list(color = "#7b2cbf", width = 3, dash = "dash"),
                                                text = ~hover,
                                                hoverinfo = "text"
                                        )
                        }
                        
                        if (nrow(current_year)) {
                                p <- p |>
                                        add_lines(
                                                data = current_year,
                                                x = ~PlotDate,
                                                y = ~attendance,
                                                name = as.character(flags$curr_year),
                                                line = list(color = "#e53935", width = 4, dash = "solid"),
                                                text = ~hover,
                                                hoverinfo = "text"
                                        )
                        }
                        
                        p |>
                                layout(
                                        xaxis = list(title = "", tickformat = "%b", dtick = "M1"),
                                        yaxis = list(title = "Average attendance", rangemode = "tozero", tickformat = ",d"),
                                        legend = list(orientation = "h", x = 0, y = 1.12),
                                        margin = list(l = 65, r = 25, b = 55, t = 55),
                                        hovermode = "x unified"
                                ) |>
                                config(displaylogo = FALSE, responsive = TRUE)
                })
        })
