                        monthly_sets()[[metric_reactive()]]
                })
                
                selected_value <- function(tbl, col) {
                        value <- tbl[[col]][1]
                        if (length(value) == 0 || !is.finite(value)) NA_real_ else as.numeric(value)
                }
                
                display_number <- function(value, accuracy = 0.1) {
                        if (is.na(value) || !is.finite(value)) {
                                "—"
                        } else {
                                comma(round(value / accuracy) * accuracy, accuracy = accuracy)
                        }
                }
                
                comparison_ui <- function(current, previous, comparison_text) {
                        pct <- safe_pct_change(current - previous, previous)
                        if (is.na(pct) || !is.finite(pct)) {
                                return(span(class = "kpi-comparison neutral", "Comparison unavailable"))
                        }
                        direction <- if (pct > 0) "up" else if (pct < 0) "down" else "flat"
                        symbol <- if (pct > 0) "↑" else if (pct < 0) "↓" else "→"
                        span(
                                class = paste("kpi-comparison", direction),
                                span(class = "direction-symbol", symbol),
                                paste0(percent(abs(pct), accuracy = 0.1), " ", comparison_text)
                        )
                }
                
                kpi_card <- function(label, value, comparison, note, accuracy = 0.1) {
                        div(
                                class = "kpi-card",
                                div(class = "kpi-label", label),
                                div(class = "kpi-value", display_number(value, accuracy)),
                                comparison,
                                div(class = "kpi-note", note)
                        )
                }
                
                output$overview_period <- renderText({
                        paste("Through", format(max(base_df()$Date, na.rm = TRUE), "%B %d, %Y"))
