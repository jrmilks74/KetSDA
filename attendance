## ------------------------------
forecastTabServer <- function(id, Weekly_data, svc_map, service_reactive, metric_reactive) {
        moduleServer(id, function(input, output, session) {
                service_labels <- c(overall = "Overall", ascent = "Ascent", sanct = "Sanctuary")
                metric_labels <- c(total = "Total", in_person = "In-person", online = "Online")
                
                settings <- eventReactive(input$fc_update, {
                        list(
                                service = service_reactive() %||% "overall",
                                metric = metric_reactive() %||% "total",
                                horizon = as.integer(input$fc_horizon %||% 26)
                        )
                }, ignoreNULL = FALSE)
                
                output$fc_heading <- renderText({
                        paste(service_labels[[settings()$service]], metric_labels[[settings()$metric]], "forecast")
                })
                
                get_base_df <- reactive({
                        make_base(Weekly_data, svc_map[[settings()$service]])
                })
                
                wk_regular <- reactive({
                        to_weekly_regular(get_base_df(), as.Date("2021-04-03"))
                })
                
                series_tbl <- reactive({
                        build_series_tbl(wk_regular(), settings()$metric)
                })
                
                holidays_df <- reactive({
                        make_holiday_df_weekly(series_tbl()$date)
                })
                
                event_uplifts <- reactive({
                        compute_event_uplifts(series_tbl())
                })
                
                .model_cache <- reactiveVal(new.env(parent = emptyenv()))
                
                get_fit <- reactive({
                        key <- paste(settings()$service, settings()$metric, settings()$horizon, sep = "_")
                        cache <- .model_cache()
                        
                        if (!exists(key, envir = cache)) {
                                fit <- withProgress(message = "Building attendance forecast", value = 0.2, {
                                        fit_result <- fit_ensemble_weighted(
                                                series_tbl = series_tbl(),
                                                holidays_df = holidays_df(),
                                                horizon_weeks = settings()$horizon,
                                                conf = 0.80
                                        )
                                        incProgress(0.8, detail = "Preparing chart and forecast table")
                                        fit_result
                                })
                                assign(key, fit, envir = cache)
                        }
                        
                        get(key, envir = cache)
                })
                
                forecast_data <- reactive({
                        fit <- get_fit()
                        
                        make_forecast(
                                refit_ens = fit$refit,
                                series_tbl = series_tbl(),
                                horizon_weeks = settings()$horizon,
                                conf = fit$conf,
                                uplifts = event_uplifts()
                        )
                })
                
                prepared_forecast <- reactive({
                        fit <- get_fit()
                        fc <- forecast_data()
                        
                        act  <- dplyr::filter(fc, .key == "actual")
                        pred <- dplyr::filter(fc, .key == "prediction")
                        
                        have_ci_cols <- all(c(".conf_lo", ".conf_hi") %in% names(pred))
                        need_ci_fallback <- !have_ci_cols || !any(is.finite(pred$.conf_lo) & is.finite(pred$.conf_hi))
                        
                        if (need_ci_fallback && nrow(pred)) {
                                acc <- fit$accuracy
                                names(acc) <- gsub("^\\.", "", names(acc))
                                acc_ok <- acc %>% dplyr::filter(is.finite(rmse))
                                
                                if (nrow(acc_ok) > 0) {
                                        if ("weight" %in% names(acc_ok) && any(is.finite(acc_ok$weight))) {
                                                wts <- acc_ok$weight
                                                wts[!is.finite(wts)] <- 0
                                                if (sum(wts) == 0) wts <- rep(1 / nrow(acc_ok), nrow(acc_ok))
                                                rmse_eff <- sum(wts * acc_ok$rmse)
                                        } else {
                                                rmse_eff <- mean(acc_ok$rmse)
                                        }
                                        
                                        z80 <- 1.281552
                                        pred$.conf_lo <- pred$.value - z80 * rmse_eff
                                        pred$.conf_hi <- pred$.value + z80 * rmse_eff
                                }
                        }
                        
                        list(actual = act, prediction = pred)
                })
                
                output$fc_accuracy <- renderUI({
                        raw_accuracy <- get_fit()$accuracy
                        
                        if (is.null(raw_accuracy) || nrow(raw_accuracy) == 0) {
                                return(p(class = "detail-intro", "Model accuracy is not available for this forecast."))
                        }
                        
                        acc <- raw_accuracy |>
                                as_tibble() |>
                                normalize_metric_names()
                        
                        required_numeric <- c("rmse", "mae", "mape", "rsq", "weight")
                        if (!"model_desc" %in% names(acc)) acc$model_desc <- "Forecast model"
                        for (column_name in required_numeric) {
                                if (!column_name %in% names(acc)) acc[[column_name]] <- NA_real_
                        }
                        
                        format_accuracy <- function(value) {
                                ifelse(is.finite(value), format(round(value, 3), trim = TRUE), "—")
                        }
                        
                        display_accuracy <- acc |>
                                transmute(
                                        Model = as.character(model_desc),
                                        RMSE = format_accuracy(rmse),
                                        MAE = format_accuracy(mae),
                                        MAPE = format_accuracy(mape),
                                        `R-squared` = format_accuracy(rsq),
                                        Weight = format_accuracy(weight)
                                )
                        
                        table_html <- kbl(
                                display_accuracy,
                                format = "html",
                                row.names = FALSE,
                                na = "—",
                                align = c("l", "r", "r", "r", "r", "r")
                        ) |>
                                kable_styling(
                                        bootstrap_options = c("striped", "responsive"),
                                        full_width = TRUE
                                )
                        
                        div(class = "table-responsive", HTML(as.character(table_html)))
                })
                
                output$fc_table <- renderTable({
                        pred <- prepared_forecast()$prediction |>
                                arrange(.index) |>
                                slice_head(n = 8)
                        
                        if (!all(c(".conf_lo", ".conf_hi") %in% names(pred))) {
                                pred$.conf_lo <- NA_real_
                                pred$.conf_hi <- NA_real_
                        }
                        
                        pred |>
                                transmute(
                                        Week = format(.index, "%b %d, %Y"),
                                        Expected = comma(round(.value)),
                                        `Likely range` = if_else(
                                                is.finite(.conf_lo) & is.finite(.conf_hi),
                                                paste0(comma(round(.conf_lo)), "–", comma(round(.conf_hi))),
                                                "—"
                                        )
                                )
                }, striped = TRUE, bordered = FALSE, spacing = "s", align = "lrr")
                
                # Native <details> elements do not always notify Shiny when
                # they are opened, so render the accuracy table in advance.
                outputOptions(output, "fc_accuracy", suspendWhenHidden = FALSE)
                
                output$fc_plot <- renderPlotly({
                        parts <- prepared_forecast()
                        act <- parts$actual
                        pred <- parts$prediction
                        
                        p <- plotly::plot_ly()
                        
                        if (nrow(pred)) {
                                if (all(c(".conf_lo", ".conf_hi") %in% names(pred)) &&
                                    any(is.finite(pred$.conf_lo) & is.finite(pred$.conf_hi))) {
                                        p <- p %>%
                                                add_ribbons(
                                                        data = pred,
                                                        x = ~.index,
                                                        ymin = ~.conf_lo,
                                                        ymax = ~.conf_hi,
                                                        name = "Likely range (80%)",
                                                        hoverinfo = "skip",
                                                        fillcolor = "rgba(110, 168, 215, 0.18)",
                                                        line = list(color = "rgba(110, 168, 215, 0)"),
                                                        opacity = 1
                                                )
                                }
                        }
                        
                        if (nrow(act)) {
                                p <- p %>% add_lines(
                                        data = act,
                                        x = ~.index,
                                        y = ~.value,
                                        name = "Recorded attendance",
                                        line = list(color = "#58a8aa", width = 3),
                                        text = ~paste0(format(.index, "%B %d, %Y"), "<br>Recorded: ", comma(round(.value))),
                                        hoverinfo = "text"
                                )
                        }
                        
                        if (nrow(pred)) {
                                p <- p %>% add_lines(
                                        data = pred,
                                        x = ~.index,
                                        y = ~.value,
                                        name = "Forecast",
                                        line = list(color = "#6ea8d7", width = 3, dash = "dash"),
                                        text = ~paste0(format(.index, "%B %d, %Y"), "<br>Forecast: ", comma(round(.value))),
                                        hoverinfo = "text"
                                )
                        }
                        
                        p %>%
                                layout(
                                        xaxis = list(title = ""),
                                        yaxis = list(title = "Attendance", rangemode = "tozero", tickformat = ",d"),
                                        legend = list(orientation = "h", x = 0, y = 1.08),
                                        margin = list(l = 65, r = 25, b = 55, t = 45),
                                        hovermode = "x unified"
                                ) |>
                                config(displaylogo = FALSE, responsive = TRUE)
